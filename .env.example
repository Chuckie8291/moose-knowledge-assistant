# Moose Knowledge Assistant — Environment Configuration
# Copy to .env and fill in your values

# ── Application ──────────────────────────────────────────
APP_NAME=Moose Knowledge Assistant
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-in-production-please-use-a-real-key-here

# ── LLM (DeepSeek — OpenAI-compatible, cheaper) ──────────
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# ── LLM (OpenAI — alternative) ───────────────────────────
# OPENAI_API_KEY=sk-your-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# ── Local Embedding (no API key needed) ──────────────────
# Uses sentence-transformers locally
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Database (optional — not needed for local demo) ──────
# DATABASE_URL=postgresql+asyncpg://moose:moose@localhost:5432/moose_assistant

# ── Elasticsearch (optional — not needed for local demo) ─
# ELASTICSEARCH_URL=http://localhost:9200

# ── FAISS Index ──────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
